# ===========================================
# BẮT BUỘC – thiếu sẽ gây lỗi 500 khi mở http://localhost:3001
# ===========================================

# Clerk (đăng nhập / bảo vệ management-portal)
# Lấy tại: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# PostgreSQL cho Prisma (blogs, bookings, packages, destinations...)
# Ví dụ: postgresql://user:password@localhost:5432/eco_tourism
DATABASE_URL="postgresql://user:password@localhost:5432/your_db"
DIRECT_URL="postgresql://user:password@localhost:5432/your_db"

# ===========================================
# TÙY CHỌN – chỉ cần khi dùng tính năng tương ứng
# ===========================================

# Upstash Redis (rate limit)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# Cron (Vercel cron)
# CRON_SECRET=

# Email (contact form, booking confirmation)
# EMAIL_USER=
# EMAIL_PASS=
# RECIPIENT_EMAIL=
# COMPANY_PHONE=

# Supabase (nếu dùng)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL API (sitemap, v.v.)
# API_URL=http://localhost:3001
